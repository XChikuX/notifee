    "@testing-library/react-native": "^12.0.0",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "@types/react-native": "^0.70",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "babel-jest": "^30.3.0",
    "eslint": "^10.0.1",
    "jest": "^30.3.0",
